{
  "rules": {
    ".read": false,
    ".write": false,
    "status": {
      ".read": true,
      ".write": "auth != null && root.child('admins').child(auth.uid).val() === true",
      "morning": {
        ".validate": "newData.isBoolean()"
      },
      "afternoon": {
        ".validate": "newData.isBoolean()"
      },
      "$other": {
        ".validate": false
      }
    },
    "results": {
      ".read": "auth != null && root.child('admins').child(auth.uid).val() === true",
      ".write": "auth != null && root.child('admins').child(auth.uid).val() === true"
    },
    "morning": {
      ".read": "auth != null && root.child('admins').child(auth.uid).val() === true",
      ".write": "auth != null && root.child('admins').child(auth.uid).val() === true",
      "$submissionId": {
        ".write": "auth != null && root.child('admins').child(auth.uid).val() === true || !data.exists()",
        ".validate": "newData.hasChildren(['type','timestamp','name','studentId','phone','dept']) && newData.child('type').val() === 'morning' && newData.child('name').isString() && newData.child('studentId').isString() && newData.child('phone').isString() && newData.child('dept').isString()"
      }
    },
    "afternoon": {
      ".read": "auth != null && root.child('admins').child(auth.uid).val() === true",
      ".write": "auth != null && root.child('admins').child(auth.uid).val() === true",
      "$submissionId": {
        ".write": "auth != null && root.child('admins').child(auth.uid).val() === true || !data.exists()",
        ".validate": "newData.hasChildren(['type','timestamp','name','studentId','phone','dept']) && newData.child('type').val() === 'afternoon' && newData.child('name').isString() && newData.child('studentId').isString() && newData.child('phone').isString() && newData.child('dept').isString()"
      }
    },
    "admins": {
      "$uid": {
        ".read": false,
        ".write": false,
        ".validate": "newData.isBoolean()"
      }
    }
  }
}
